# Copy this file to k8s-secrets.yaml and replace the placeholder with your real token.
# k8s-secrets.yaml is gitignored and will NOT be committed.
#
# To get a Cloudflare API token:
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Create a token with Zone:DNS:Edit permission for your domain
#   3. Base64 encode it: echo -n 'your-token-here' | base64
#   4. Paste the base64 value below
#
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token-secret
  namespace: cert
type: Opaque
data:
  api-token: <BASE64_ENCODED_CLOUDFLARE_API_TOKEN>
